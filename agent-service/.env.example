# LLM provider. Only "openai" is implemented today; the LLMClient interface
# is provider-agnostic so another provider (e.g. anthropic) can be added
# later without touching orchestration code.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1

# quote-service integration (see ../docker-compose.yml).
QUOTE_SERVICE_BASE_URL=http://localhost:8000
QUOTE_SERVICE_CONNECT_TIMEOUT_SECONDS=3.0
# Must stay comfortably above quote-service's QUOTE_SLOW_SECONDS (default 8s)
# or a slow-but-successful call gets misclassified as a failure.
QUOTE_SERVICE_READ_TIMEOUT_SECONDS=15.0
QUOTE_SERVICE_MAX_ATTEMPTS=3
QUOTE_SERVICE_BACKOFF_BASE_SECONDS=0.5
QUOTE_SERVICE_BACKOFF_MULTIPLIER=2.0
QUOTE_SERVICE_BACKOFF_MAX_SECONDS=4.0
QUOTE_SERVICE_BACKOFF_JITTER=0.2

# Agent behavior bounds.
MAX_FIELD_ATTEMPTS=2
MAX_TOOL_ITERATIONS=4

LOG_LEVEL=INFO

# Comma-separated list of origins allowed to call this API from a browser
# (the frontend's Vite dev server origin).
CORS_ALLOW_ORIGINS=http://localhost:5173
